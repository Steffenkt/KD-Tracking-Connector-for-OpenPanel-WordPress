#. Plugin Name of the plugin
#: openpanel-self-hosted.php
msgid "OpenPanel Self-Hosted"
msgstr "OpenPanel Self-Hosted"

#. Description of the plugin
#: openpanel-self-hosted.php
msgid "Bindet OpenPanel Analytics in WordPress ein. Unterstützt Self-Hosted-Instanzen und die offizielle Cloud. Konfigurierbar unter Einstellungen → OpenPanel."
msgstr "Integrates OpenPanel Analytics into WordPress. Supports self-hosted instances and the official cloud. Configurable under Settings → OpenPanel."

#: openpanel-self-hosted.php
msgid "OpenPanel Analytics"
msgstr "OpenPanel Analytics"

#: openpanel-self-hosted.php
msgid "OpenPanel"
msgstr "OpenPanel"

#: openpanel-self-hosted.php
msgid "Allgemein"
msgstr "General"

#: openpanel-self-hosted.php
msgid "OpenPanel aktivieren"
msgstr "Enable OpenPanel"

#: openpanel-self-hosted.php
msgid "Tracking-Script im Frontend ausgeben."
msgstr "Output tracking script in the frontend."

#: openpanel-self-hosted.php
msgid "Client ID"
msgstr "Client ID"

#: openpanel-self-hosted.php
msgid "Die Client-ID deiner OpenPanel-Anwendung."
msgstr "The Client ID of your OpenPanel application."

#: openpanel-self-hosted.php
msgid "API-URL (Self-Hosted)"
msgstr "API URL (Self-Hosted)"

#: openpanel-self-hosted.php
msgid "Nur bei Self-Hosting angeben, z.&nbsp;B. https://openpanel.example.com/api. Leer lassen für die offizielle Cloud."
msgstr "Only set for self-hosting, e.g. https://openpanel.example.com/api. Leave empty for the official cloud."

#: openpanel-self-hosted.php
msgid "Script-Auslieferung"
msgstr "Script Delivery"

#: openpanel-self-hosted.php
msgid "op1.js lokal ausliefern"
msgstr "Serve op1.js locally"

#: openpanel-self-hosted.php
msgid "Script aus dem Plugin-Ordner laden (kein externer Request zu openpanel.dev). Deaktiviert: Script wird von https://openpanel.dev/op1.js geladen."
msgstr "Load script from the plugin folder (no external request to openpanel.dev). Disabled: script will be loaded from https://openpanel.dev/op1.js."

#: openpanel-self-hosted.php
msgid "Tracking-Optionen"
msgstr "Tracking Options"

#: openpanel-self-hosted.php
msgid "Seitenaufrufe (trackScreenViews)"
msgstr "Page Views (trackScreenViews)"

#: openpanel-self-hosted.php
msgid "Seitenaufrufe automatisch tracken."
msgstr "Automatically track page views."

#: openpanel-self-hosted.php
msgid "Ausgehende Links (trackOutgoingLinks)"
msgstr "Outgoing Links (trackOutgoingLinks)"

#: openpanel-self-hosted.php
msgid "Klicks auf externe Links automatisch tracken."
msgstr "Automatically track clicks on external links."

#: openpanel-self-hosted.php
msgid "HTML-Attribute (trackAttributes)"
msgstr "HTML Attributes (trackAttributes)"

#: openpanel-self-hosted.php
msgid "Tracking über data-track-Attribute an HTML-Elementen."
msgstr "Tracking via data-track attributes on HTML elements."

#: openpanel-self-hosted.php
msgid "Session Replay"
msgstr "Session Replay"

#: openpanel-self-hosted.php
msgid "Session Replay aktivieren"
msgstr "Enable Session Replay"

#: openpanel-self-hosted.php
msgid "Mausbewegungen, Scrollverhalten und Klicks aufzeichnen."
msgstr "Record mouse movements, scroll behavior, and clicks."

#: openpanel-self-hosted.php
msgid "Formularfelder maskieren (maskAllInputs)"
msgstr "Mask form fields (maskAllInputs)"

#: openpanel-self-hosted.php
msgid "Empfohlen: Verhindert, dass Eingaben in Formularfelder im Replay sichtbar sind."
msgstr "Recommended: Prevents form field inputs from being visible in the replay."

#: openpanel-self-hosted.php
msgid "Datenschutz &amp; Debug"
msgstr "Privacy &amp; Debug"

#: openpanel-self-hosted.php
msgid "Eingeloggte Nutzer nicht tracken"
msgstr "Do not track logged-in users"

#: openpanel-self-hosted.php
msgid "Admins und eingeloggte Benutzer werden nicht getrackt – verhindert verfälschte Statistiken."
msgstr "Admins and logged-in users will not be tracked – prevents skewed statistics."

#: openpanel-self-hosted.php
msgid "Do Not Track (DNT) respektieren"
msgstr "Respect Do Not Track (DNT)"

#: openpanel-self-hosted.php
msgid "Nutzer mit aktivem DNT-Browser-Header werden nicht getrackt."
msgstr "Users with an active DNT browser header will not be tracked."

#: openpanel-self-hosted.php
msgid "Bei WP_DEBUG deaktivieren"
msgstr "Disable when WP_DEBUG is active"

#: openpanel-self-hosted.php
msgid "Kein Tracking auf lokalen/Staging-Umgebungen wenn WP_DEBUG aktiv ist."
msgstr "No tracking on local/staging environments when WP_DEBUG is active."

#: openpanel-self-hosted.php
msgid "Änderungen speichern"
msgstr "Save Changes"
